[Unit]
Description=Lyon Transit SpacetimeDB
After=network-online.target
Wants=network-online.target

[Service]
User={{USER}}
WorkingDirectory={{PROJECT_DIR}}
ExecStart=/usr/bin/spacetime start --listen-addr 127.0.0.1:3000 --non-interactive
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target

