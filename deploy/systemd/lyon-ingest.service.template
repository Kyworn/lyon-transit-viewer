[Unit]
Description=Lyon Transit Ingestion Daemon
After=lyon-spacetime.service
Requires=lyon-spacetime.service

[Service]
User={{USER}}
WorkingDirectory={{PROJECT_DIR}}
Environment=DB_NAME={{DB_NAME}}
Environment=SERVER_URL=http://127.0.0.1:3000
ExecStart={{PROJECT_DIR}}/scripts/ingest_daemon.sh
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target

